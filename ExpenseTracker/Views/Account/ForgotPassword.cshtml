@model ExpenseTracker.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-wrapper fade-in">
    <div class="auth-card card">
        <div class="auth-header">
            <span class="auth-icon"><i class="fas fa-unlock-alt"></i></span>
            <h3 class="mb-1">Forgot Password</h3>
            <p class="mb-0 opacity-75" style="font-size:.9rem;">Enter your email to receive a reset link</p>
        </div>
        <div class="auth-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label asp-for="Email" class="form-label">
                        <i class="fas fa-envelope me-1 text-muted"></i>Email Address
                    </label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                    </button>
                </div>
            </form>
        </div>
        <div class="auth-footer">
            <a asp-action="Login" class="fw-bold">
                <i class="fas fa-arrow-left me-1"></i>Back to Sign In
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
