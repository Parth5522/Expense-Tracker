@{
    ViewData["Title"] = "Reset Link Sent";
    var resetLink = TempData["ResetLink"] as string;
}

<div class="auth-wrapper fade-in">
    <div class="auth-card card">
        <div class="auth-header">
            <span class="auth-icon"><i class="fas fa-envelope-open-text"></i></span>
            <h3 class="mb-1">Check Your Email</h3>
        </div>
        <div class="auth-body">
            @if (!string.IsNullOrEmpty(resetLink))
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Demo Mode:</strong> No email server is configured.
                    Use the link below to reset your password:
                </div>
                <div class="card bg-light mb-3">
                    <div class="card-body py-2 px-3">
                        <a href="@resetLink" class="text-break small">@resetLink</a>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted">
                    If an account with that email exists, a password reset link has been sent.
                    Please check your inbox and follow the instructions.
                </p>
            }
        </div>
        <div class="auth-footer">
            <a asp-action="Login" class="fw-bold">
                <i class="fas fa-arrow-left me-1"></i>Back to Sign In
            </a>
        </div>
    </div>
</div>
