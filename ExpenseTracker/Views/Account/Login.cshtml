@model ExpenseTracker.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-wrapper fade-in">
    <div class="auth-card card">
        <div class="auth-header">
            <span class="auth-icon"><i class="fas fa-wallet"></i></span>
            <h3 class="mb-1">Welcome Back</h3>
            <p class="mb-0 opacity-75" style="font-size:.9rem;">Sign in to your FinTrack account</p>
        </div>
        <div class="auth-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"><i class="fas fa-envelope me-1 text-muted"></i>Email</label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"><i class="fas fa-lock me-1 text-muted"></i>Password</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                    <label asp-for="RememberMe" class="form-check-label text-muted">Remember me</label>
                    <div class="mt-1">
                        <a asp-action="ForgotPassword" class="small text-primary">Forgot your password?</a>
                    </div>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-sign-in-alt me-2"></i>Sign In
                    </button>
                </div>
            </form>
        </div>
        <div class="auth-footer">
            <span class="text-muted">Don't have an account?</span>
            <a asp-controller="Account" asp-action="Register" class="ms-1 fw-bold">Create one free</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
