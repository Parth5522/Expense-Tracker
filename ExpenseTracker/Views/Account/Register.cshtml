@model ExpenseTracker.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-wrapper fade-in">
    <div class="auth-card card" style="max-width:500px;">
        <div class="auth-header">
            <span class="auth-icon"><i class="fas fa-user-plus"></i></span>
            <h3 class="mb-1">Create Account</h3>
            <p class="mb-0 opacity-75" style="font-size:.9rem;">Start tracking your expenses today</p>
        </div>
        <div class="auth-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label"><i class="fas fa-user me-1 text-muted"></i>Display Name</label>
                    <input asp-for="DisplayName" class="form-control" placeholder="Your name" autocomplete="name" />
                    <span asp-validation-for="DisplayName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"><i class="fas fa-envelope me-1 text-muted"></i>Email</label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label asp-for="Password" class="form-label"><i class="fas fa-lock me-1 text-muted"></i>Password</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="Create password" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="ConfirmPassword" class="form-label"><i class="fas fa-lock me-1 text-muted"></i>Confirm</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mb-4">
                    <label asp-for="BaseCurrency" class="form-label"><i class="fas fa-coins me-1 text-muted"></i>Base Currency</label>
                    <select asp-for="BaseCurrency" class="form-select">
                        <option value="USD">USD – US Dollar</option>
                        <option value="EUR">EUR – Euro</option>
                        <option value="GBP">GBP – British Pound</option>
                        <option value="INR">INR – Indian Rupee</option>
                        <option value="JPY">JPY – Japanese Yen</option>
                        <option value="CAD">CAD – Canadian Dollar</option>
                        <option value="AUD">AUD – Australian Dollar</option>
                    </select>
                    <span asp-validation-for="BaseCurrency" class="text-danger small"></span>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-user-plus me-2"></i>Create Account
                    </button>
                </div>
            </form>
        </div>
        <div class="auth-footer">
            <span class="text-muted">Already have an account?</span>
            <a asp-controller="Account" asp-action="Login" class="ms-1 fw-bold">Sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
