@model ExpenseTracker.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-wrapper fade-in">
    <div class="auth-card card">
        <div class="auth-header">
            <span class="auth-icon"><i class="fas fa-lock-open"></i></span>
            <h3 class="mb-1">Reset Your Password</h3>
            <p class="mb-0 opacity-75" style="font-size:.9rem;">Choose a new password for your account</p>
        </div>
        <div class="auth-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />
                <div class="mb-3">
                    <label class="form-label text-muted small">
                        <i class="fas fa-envelope me-1"></i>Resetting password for: <strong>@Model.Email</strong>
                    </label>
                </div>
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label">
                        <i class="fas fa-lock me-1 text-muted"></i>New Password
                    </label>
                    <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">
                        <i class="fas fa-lock me-1 text-muted"></i>Confirm Password
                    </label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save me-2"></i>Reset Password
                    </button>
                </div>
            </form>
        </div>
        <div class="auth-footer">
            <a asp-action="Login" class="fw-bold">
                <i class="fas fa-arrow-left me-1"></i>Back to Sign In
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
