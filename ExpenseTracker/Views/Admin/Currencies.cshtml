@model IEnumerable<ExpenseTracker.Models.Currency>
@{
    ViewData["Title"] = "Currency Management";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold"><i class="fas fa-coins me-2"></i>Currency Management</h1>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Admin
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-coins me-2"></i>Supported Currencies
            <span class="badge bg-primary ms-1">@Model.Count() currencies</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Symbol</th>
                            <th class="text-end">Rate to USD</th>
                            <th>Last Updated</th>
                            <th>Update Rate</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var currency in Model)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@currency.Code</span></td>
                                <td>@currency.Name</td>
                                <td><strong>@currency.Symbol</strong></td>
                                <td class="text-end">@currency.RateToUsd.ToString("N4")</td>
                                <td>@currency.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>
                                    @if (currency.Code != "USD")
                                    {
                                        <form asp-action="UpdateRate" method="post" class="d-flex gap-2 align-items-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="code" value="@currency.Code" />
                                            <input type="number" name="rateToUsd" class="form-control form-control-sm"
                                                   style="width:110px;" step="0.0001" min="0.0001"
                                                   value="@currency.RateToUsd.ToString("0.0000")"
                                                   required />
                                            <button type="submit" class="btn btn-sm btn-primary" title="Update rate">
                                                <i class="fas fa-save"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Base currency</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="alert alert-info mt-3 mb-0">
                <i class="fas fa-info-circle me-2"></i>
                Exchange rates are expressed as units of currency per 1 USD. Update them to reflect current market prices.
            </div>
        </div>
    </div>
</div>
