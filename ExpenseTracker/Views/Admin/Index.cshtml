@{
    ViewData["Title"] = "Admin Dashboard";
    var userSummaries = ViewBag.UserSummaries as IEnumerable<dynamic>;
}

<div class="fade-in">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-shield-alt"></i>Admin Dashboard</h1>
    </div>

    <!-- System Stats -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">Total Users</div>
                        <div class="stat-value">@ViewBag.UserCount</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card danger">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">Total Expenses</div>
                        <div class="stat-value">@string.Format("{0:N2}", ViewBag.TotalExpenses)</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-money-bill-wave"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card success">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">Total Income</div>
                        <div class="stat-value">@string.Format("{0:N2}", ViewBag.TotalIncome)</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card info">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">Total Transactions</div>
                        <div class="stat-value">@(ViewBag.TotalExpenseCount + ViewBag.TotalIncomeCount)</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-receipt"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Navigation Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <a asp-action="Users" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center p-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3 mx-auto mb-2" style="width:fit-content;">
                        <i class="fas fa-users-cog fa-2x text-primary"></i>
                    </div>
                    <div class="fw-semibold">Manage Users</div>
                    <div class="text-muted small">Toggle roles &amp; delete accounts</div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-action="Currencies" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center p-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3 mx-auto mb-2" style="width:fit-content;">
                        <i class="fas fa-coins fa-2x text-success"></i>
                    </div>
                    <div class="fw-semibold">Currencies</div>
                    <div class="text-muted small">Update exchange rates</div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-action="AllExpenses" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center p-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3 mx-auto mb-2" style="width:fit-content;">
                        <i class="fas fa-receipt fa-2x text-danger"></i>
                    </div>
                    <div class="fw-semibold">All Expenses</div>
                    <div class="text-muted small">View system-wide expenses</div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-action="AllIncome" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center p-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3 mx-auto mb-2" style="width:fit-content;">
                        <i class="fas fa-dollar-sign fa-2x text-warning"></i>
                    </div>
                    <div class="fw-semibold">All Income</div>
                    <div class="text-muted small">View system-wide income</div>
                </div>
            </a>
        </div>
    </div>

    <!-- Monthly User Summary -->
    <div class="card">
        <div class="card-header">
            <i class="fas fa-calendar-alt me-2"></i>Monthly Expense &amp; Income by User
            <span class="badge bg-secondary ms-1">@ViewBag.MonthLabel</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th class="text-danger">Monthly Expenses</th>
                            <th class="text-success">Monthly Income</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (userSummaries != null)
                        {
                            @foreach (var item in userSummaries)
                            {
                                <tr>
                                    <td>@(item.User.DisplayName ?? item.User.UserName ?? item.User.Email ?? "Unknown")</td>
                                    <td>@item.User.Email</td>
                                    <td class="text-danger fw-semibold">@item.MonthlyExpense.ToString("N2")</td>
                                    <td class="text-success fw-semibold">@item.MonthlyIncome.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
