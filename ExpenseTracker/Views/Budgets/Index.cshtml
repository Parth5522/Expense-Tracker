@model IEnumerable<ExpenseTracker.Models.Budget>
@{
    ViewData["Title"] = "Budgets";
    var month = (int)ViewBag.Month;
    var year = (int)ViewBag.Year;
    var budgetStatuses = ViewBag.BudgetStatuses as List<(ExpenseTracker.Models.Budget Budget, decimal Spent, bool Exceeded)>;
    var recommendations = ViewBag.Recommendations as List<string> ?? new List<string>();
    var monthName = new DateTime(year, month, 1).ToString("MMMM yyyy");

    // Build chart data
    var chartLabels = System.Text.Json.JsonSerializer.Serialize(
        budgetStatuses?.Select(s => s.Budget.Category.HasValue ? s.Budget.Category.ToString() : "Overall") ?? Enumerable.Empty<string>());
    var chartSpent = System.Text.Json.JsonSerializer.Serialize(
        budgetStatuses?.Select(s => s.Spent) ?? Enumerable.Empty<decimal>());
    var chartRemaining = System.Text.Json.JsonSerializer.Serialize(
        budgetStatuses?.Select(s => Math.Max(s.Budget.Amount - s.Spent, 0)) ?? Enumerable.Empty<decimal>());
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold"><i class="fas fa-piggy-bank me-2"></i>Budgets</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create Budget
        </a>
    </div>

    <!-- Month/Year Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Month</label>
                    <select name="month" class="form-select">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == month)">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Year</label>
                    <select name="year" class="form-select">
                        @for (int y = 2023; y <= 2026; y++)
                        {
                            <option value="@y" selected="@(y == year)">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>View
                    </button>
                </div>
            </form>
        </div>
    </div>

    <h4 class="mb-3"><i class="fas fa-calendar me-2"></i>@monthName</h4>

    @if (budgetStatuses != null && budgetStatuses.Any())
    {
        <!-- Overview doughnut chart -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-header"><i class="fas fa-chart-pie me-2 text-primary"></i>Budget Usage Overview</div>
                    <div class="card-body d-flex justify-content-center align-items-center">
                        <canvas id="budgetChart" style="max-height:220px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card h-100">
                    <div class="card-header"><i class="fas fa-chart-bar me-2 text-info"></i>Spent vs Budget</div>
                    <div class="card-body">
                        <canvas id="budgetBarChart" height="120"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recommendations -->
        @if (recommendations.Any())
        {
            <div class="card mb-4 border-info">
                <div class="card-header text-info">
                    <i class="fas fa-lightbulb me-2"></i>Budget Recommendations
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        @foreach (var rec in recommendations)
                        {
                            <li class="mb-1">@rec</li>
                        }
                    </ul>
                </div>
            </div>
        }

        <div class="row g-4">
            @foreach (var status in budgetStatuses)
            {
                var progressPct = status.Budget.Amount > 0 ? (double)(status.Spent / status.Budget.Amount * 100) : 0;
                progressPct = Math.Min(progressPct, 100);
                var remaining = status.Budget.Amount - status.Spent;
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 @(status.Exceeded ? "border-danger" : "")">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>
                                <i class="fas fa-tag me-1"></i>
                                @(status.Budget.Category.HasValue ? status.Budget.Category.ToString() : "Overall")
                            </span>
                            @if (status.Exceeded)
                            {
                                <span class="badge bg-danger"><i class="fas fa-exclamation-triangle me-1"></i>Exceeded</span>
                            }
                            else if (progressPct >= 80)
                            {
                                <span class="badge bg-warning text-dark"><i class="fas fa-exclamation-circle me-1"></i>Near Limit</span>
                            }
                            else
                            {
                                <span class="badge bg-success">On Track</span>
                            }
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Budget</span>
                                <strong>@status.Budget.Currency @status.Budget.Amount.ToString("N2")</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Spent</span>
                                <strong class="@(status.Exceeded ? "text-danger" : "text-warning")">@status.Budget.Currency @status.Spent.ToString("N2")</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-muted">Remaining</span>
                                <strong class="@(remaining < 0 ? "text-danger" : "text-success")">@status.Budget.Currency @remaining.ToString("N2")</strong>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar @(status.Exceeded ? "bg-danger" : progressPct > 75 ? "bg-warning" : "bg-success")"
                                     role="progressbar"
                                     style="width: @progressPct.ToString("F0")%"
                                     aria-valuenow="@progressPct.ToString("F0")"
                                     aria-valuemin="0"
                                     aria-valuemax="100"></div>
                            </div>
                            <div class="text-muted small mt-1 text-end">@progressPct.ToString("F0")% used</div>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@status.Budget.Id" class="btn btn-sm btn-outline-warning flex-fill">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@status.Budget.Id" class="btn btn-sm btn-outline-danger flex-fill">
                                <i class="fas fa-trash me-1"></i>Delete
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-piggy-bank fa-4x text-muted mb-3"></i>
                <h4>No Budgets Found</h4>
                <p class="text-muted">No budgets set for @monthName.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Create Budget
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    @if (budgetStatuses != null && budgetStatuses.Any())
    {
        <script>
        (function () {
            var labels    = @Html.Raw(chartLabels);
            var spent     = @Html.Raw(chartSpent);
            var remaining = @Html.Raw(chartRemaining);
            var colors    = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#06b6d4','#14b8a6','#64748b'];

            // Doughnut: spent vs remaining for each budget
            var doughnutData = [];
            var doughnutLabels = [];
            var doughnutColors = [];
            labels.forEach(function(lbl, i) {
                doughnutLabels.push(lbl + ' (Spent)');
                doughnutData.push(spent[i]);
                doughnutColors.push(colors[i % colors.length]);
                if (remaining[i] > 0) {
                    doughnutLabels.push(lbl + ' (Free)');
                    doughnutData.push(remaining[i]);
                    doughnutColors.push(colors[i % colors.length] + '55');
                }
            });
            new Chart(document.getElementById('budgetChart'), {
                type: 'doughnut',
                data: {
                    labels: doughnutLabels,
                    datasets: [{ data: doughnutData, backgroundColor: doughnutColors }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } } }
            });

            // Bar: spent vs budget amount
            var budgetAmounts = spent.map(function(s, i) { return s + remaining[i]; });
            new Chart(document.getElementById('budgetBarChart'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Spent', data: spent, backgroundColor: 'rgba(239,68,68,0.75)' },
                        { label: 'Budget', data: budgetAmounts, backgroundColor: 'rgba(34,197,94,0.35)', borderColor: 'rgba(34,197,94,1)', borderWidth: 1 }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top' } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        })();
        </script>
    }
}

