@model ExpenseTracker.Models.Expense
@{
    ViewData["Title"] = "Delete Expense";
    var currencySymbol = User.FindFirst("CurrencySymbol")?.Value ?? "$";
}

<div class="fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Delete Expense</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this expense? This action cannot be undone.
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">
                            <i class="fas fa-heading me-2"></i>Title
                        </dt>
                        <dd class="col-sm-9">
                            @Model.Title
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-align-left me-2"></i>Description
                        </dt>
                        <dd class="col-sm-9">
                            @(Model.Description ?? "N/A")
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-dollar-sign me-2"></i>Amount
                        </dt>
                        <dd class="col-sm-9">
                            <span class="amount-display">@currencySymbol@Model.Amount.ToString("N2")</span>
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-tag me-2"></i>Category
                        </dt>
                        <dd class="col-sm-9">
                            <span class="badge category-@Model.Category.ToString().ToLower() fs-6">
                                @Model.Category
                            </span>
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-calendar me-2"></i>Date
                        </dt>
                        <dd class="col-sm-9">
                            @Model.Date.ToString("MMMM dd, yyyy")
                        </dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
