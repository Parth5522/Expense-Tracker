@model ExpenseTracker.Models.Expense
@{
    ViewData["Title"] = "Expense Details";
    var currencySymbol = User.FindFirst("CurrencySymbol")?.Value ?? "$";
}

<div class="fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0"><i class="fas fa-info-circle me-2"></i>Expense Details</h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">
                            <i class="fas fa-heading me-2"></i>Title
                        </dt>
                        <dd class="col-sm-9">
                            @Model.Title
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-align-left me-2"></i>Description
                        </dt>
                        <dd class="col-sm-9">
                            @(Model.Description ?? "N/A")
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-dollar-sign me-2"></i>Amount
                        </dt>
                        <dd class="col-sm-9">
                            <span class="text-danger amount-display">@currencySymbol@Model.Amount.ToString("N2")</span>
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-tag me-2"></i>Category
                        </dt>
                        <dd class="col-sm-9">
                            <span class="badge category-@Model.Category.ToString().ToLower() fs-6">
                                @Model.Category
                            </span>
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-calendar me-2"></i>Date
                        </dt>
                        <dd class="col-sm-9">
                            @Model.Date.ToString("MMMM dd, yyyy")
                        </dd>

                        <dt class="col-sm-3">
                            <i class="fas fa-clock me-2"></i>Created At
                        </dt>
                        <dd class="col-sm-9">
                            @Model.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")
                        </dd>
                    </dl>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="fas fa-edit me-2"></i>Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
