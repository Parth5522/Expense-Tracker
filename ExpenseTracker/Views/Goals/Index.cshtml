@model IEnumerable<ExpenseTracker.Models.Goal>
@{
    ViewData["Title"] = "Goals";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold"><i class="fas fa-bullseye me-2"></i>Goals</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create Goal
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">@item.Name</h5>
                            @if (item.IsAchieved)
                            {
                                <span class="badge bg-success"><i class="fas fa-check me-1"></i>Achieved</span>
                            }
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="text-muted small">@item.Description</p>
                            }
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="text-muted">Progress</small>
                                    <small class="fw-bold">@item.ProgressPercentage.ToString("N0")%</small>
                                </div>
                                <div class="progress" style="height: 10px;">
                                    <div class="progress-bar @(item.IsAchieved ? "bg-success" : "bg-primary")"
                                         role="progressbar"
                                         style="width: @item.ProgressPercentage%"
                                         aria-valuenow="@item.ProgressPercentage"
                                         aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                            <div class="row text-center mb-2">
                                <div class="col-6">
                                    <small class="text-muted d-block">Target</small>
                                    <strong>@item.Currency @item.TargetAmount.ToString("N2")</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Current</small>
                                    <strong class="text-success">@item.Currency @item.CurrentAmount.ToString("N2")</strong>
                                </div>
                            </div>
                            @if (!item.IsAchieved)
                            {
                                <p class="text-center mb-2">
                                    <small class="text-muted">Remaining: </small>
                                    <strong class="text-warning">@item.Currency @item.RemainingAmount.ToString("N2")</strong>
                                </p>
                            }
                            @if (item.TargetDate.HasValue)
                            {
                                <p class="text-center mb-0">
                                    <small class="text-muted"><i class="fas fa-calendar me-1"></i>Target: @item.TargetDate.Value.ToString("MMM dd, yyyy")</small>
                                </p>
                            }
                        </div>
                        <div class="card-footer d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <form asp-controller="Goals" asp-action="Delete" asp-route-id="@item.Id" method="post" asp-antiforgery="true" onsubmit="return confirm('Are you sure you want to delete this goal?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash me-1"></i>Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-bullseye"></i>
            <h3>No Goals Yet</h3>
            <p>Start tracking your financial goals</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Create Your First Goal
            </a>
        </div>
    }
</div>
