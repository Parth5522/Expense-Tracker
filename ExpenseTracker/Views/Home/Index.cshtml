@model ExpenseTracker.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold"><i class="fas fa-chart-line me-2"></i>Dashboard</h1>
        <a asp-controller="Expenses" asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add New Expense
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Total Expenses</div>
                        <div class="stat-value">$@Model.TotalExpenses.ToString("N2")</div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-money-bill-wave"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Monthly Expenses</div>
                        <div class="stat-value">$@Model.MonthlyExpenses.ToString("N2")</div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Average Expense</div>
                        <div class="stat-value">$@Model.AverageExpense.ToString("N2")</div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Total Transactions</div>
                        <div class="stat-value">@Model.TransactionCount</div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-receipt"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-pie-chart me-2"></i>Expenses by Category
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-chart-line me-2"></i>Monthly Spending Trends
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="trendsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-history me-2"></i>Recent Transactions</span>
                    <a asp-controller="Expenses" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        View All <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.RecentTransactions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Title</th>
                                        <th>Category</th>
                                        <th class="text-end">Amount</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var expense in Model.RecentTransactions)
                                    {
                                        <tr>
                                            <td>@expense.Date.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                <strong>@expense.Title</strong>
                                                @if (!string.IsNullOrEmpty(expense.Description))
                                                {
                                                    <br /><small class="text-muted">@expense.Description</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge category-@expense.Category.ToString().ToLower()">
                                                    @expense.Category
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <strong class="text-success">$@expense.Amount.ToString("N2")</strong>
                                            </td>
                                            <td>
                                                <a asp-controller="Expenses" asp-action="Details" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-info" title="Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-controller="Expenses" asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-inbox"></i>
                            <h3>No Transactions Yet</h3>
                            <p>Start tracking your expenses by adding your first transaction</p>
                            <a asp-controller="Expenses" asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>Add First Expense
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Category Chart Data
        var categoryLabels = @Html.Raw(Json.Serialize(Model.ExpensesByCategory.Keys));
        var categoryData = @Html.Raw(Json.Serialize(Model.ExpensesByCategory.Values));
        
        // Category Chart
        var categoryCtx = document.getElementById('categoryChart').getContext('2d');
        new Chart(categoryCtx, {
            type: 'doughnut',
            data: {
                labels: categoryLabels,
                datasets: [{
                    data: categoryData,
                    backgroundColor: [
                        '#ff6b6b', '#4ecdc4', '#45b7d1', '#96ceb4', '#ffeaa7',
                        '#dfe6e9', '#a29bfe', '#fd79a8', '#fdcb6e', '#6c5ce7'
                    ],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                var label = context.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                label += '$' + context.parsed.toFixed(2);
                                return label;
                            }
                        }
                    }
                }
            }
        });

        // Trends Chart Data
        var trendsLabels = @Html.Raw(Json.Serialize(Model.MonthlyTrends.Keys));
        var trendsData = @Html.Raw(Json.Serialize(Model.MonthlyTrends.Values));
        
        // Trends Chart
        var trendsCtx = document.getElementById('trendsChart').getContext('2d');
        new Chart(trendsCtx, {
            type: 'bar',
            data: {
                labels: trendsLabels,
                datasets: [{
                    label: 'Monthly Expenses',
                    data: trendsData,
                    backgroundColor: 'rgba(13, 110, 253, 0.7)',
                    borderColor: 'rgba(13, 110, 253, 1)',
                    borderWidth: 2,
                    borderRadius: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return '$' + context.parsed.y.toFixed(2);
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return '$' + value;
                            }
                        }
                    }
                }
            }
        });
    </script>
}
