@model ExpenseTracker.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var currencySymbol = User.FindFirst("CurrencySymbol")?.Value ?? "$";
}

<div class="fade-in">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-chart-line"></i>Dashboard</h1>
        <a asp-controller="Expenses" asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Expense
        </a>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">Total Expenses</div>
                        <div class="stat-value">@currencySymbol@Model.TotalExpenses.ToString("N2")</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-money-bill-wave"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card success">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">This Month</div>
                        <div class="stat-value">@currencySymbol@Model.MonthlyExpenses.ToString("N2")</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card warning">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">Avg. Expense</div>
                        <div class="stat-value">@currencySymbol@Model.AverageExpense.ToString("N2")</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-chart-bar"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="stat-card info">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">Total Transactions</div>
                        <div class="stat-value">@Model.TransactionCount</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-receipt"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-3 mb-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header">
                    <i class="fas fa-chart-pie me-2 text-primary"></i>Expenses by Category
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header">
                    <i class="fas fa-chart-line me-2 text-primary"></i>Monthly Spending Trends
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="trendsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-history me-2 text-primary"></i>Recent Transactions</span>
            <a asp-controller="Expenses" asp-action="Index" class="btn btn-sm btn-outline-primary">
                View All <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="card-body p-0">
            @if (Model.RecentTransactions.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-card-mobile mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Title</th>
                                <th>Category</th>
                                <th class="text-end">Amount</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var expense in Model.RecentTransactions)
                            {
                                <tr>
                                    <td data-label="Date">@expense.Date.ToString("MMM dd, yyyy")</td>
                                    <td data-label="Title">
                                        <strong>@expense.Title</strong>
                                        @if (!string.IsNullOrEmpty(expense.Description))
                                        {
                                            <br /><small class="text-muted">@expense.Description</small>
                                        }
                                    </td>
                                    <td data-label="Category">
                                        <span class="badge category-@expense.Category.ToString().ToLower()">
                                            @expense.Category
                                        </span>
                                    </td>
                                    <td data-label="Amount" class="text-end">
                                        <strong class="text-success">@currencySymbol@expense.Amount.ToString("N2")</strong>
                                    </td>
                                    <td class="td-actions text-end">
                                        <a asp-controller="Expenses" asp-action="Details" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-controller="Expenses" asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h3>No Transactions Yet</h3>
                    <p>Start tracking your expenses by adding your first transaction</p>
                    <a asp-controller="Expenses" asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Add First Expense
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currencySymbol = '@Html.Raw(currencySymbol)';
        var categoryLabels = @Html.Raw(Json.Serialize(Model.ExpensesByCategory.Keys));
        var categoryData   = @Html.Raw(Json.Serialize(Model.ExpensesByCategory.Values));

        new Chart(document.getElementById('categoryChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: categoryLabels,
                datasets: [{
                    data: categoryData,
                    backgroundColor: [
                        '#818cf8','#34d399','#fbbf24','#f87171','#60a5fa',
                        '#a78bfa','#fb923c','#4ade80','#38bdf8','#f472b6'
                    ],
                    borderWidth: 2,
                    borderColor: '#fff',
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { position: 'right', labels: { boxWidth: 12, padding: 14, font: { size: 12 } } },
                    tooltip: {
                        callbacks: {
                            label: function (c) {
                                return (c.label || '') + ': ' + currencySymbol + c.parsed.toFixed(2);
                            }
                        }
                    }
                }
            }
        });

        var trendsLabels = @Html.Raw(Json.Serialize(Model.MonthlyTrends.Keys));
        var trendsData   = @Html.Raw(Json.Serialize(Model.MonthlyTrends.Values));

        new Chart(document.getElementById('trendsChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: trendsLabels,
                datasets: [{
                    label: 'Monthly Expenses',
                    data: trendsData,
                    backgroundColor: 'rgba(79,70,229,0.75)',
                    borderColor: 'rgba(79,70,229,1)',
                    borderWidth: 0,
                    borderRadius: 8,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: { label: function (c) { return currencySymbol + c.parsed.y.toFixed(2); } }
                    }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f1f5f9' },
                        ticks: { callback: function (v) { return currencySymbol + v; } }
                    }
                }
            }
        });
    </script>
}
