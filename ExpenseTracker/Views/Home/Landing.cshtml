<!-- ===================== CTA BANNER ===================== -->
<section class="lp-cta">
    <div class="lp-cta-shape lp-cta-s1"></div>
    <div class="lp-cta-shape lp-cta-s2"></div>
    <div class="container lp-cta-inner">
        <h2 class="lp-cta-title">Ready to take control of your finances?</h2>
        <p class="lp-cta-sub">Join thousands of users who have already transformed their financial lives.</p>
        <div class="lp-cta-actions">
            <a asp-controller="Account" asp-action="Register" class="btn lp-btn-white">
                <i class="fas fa-rocket me-2"></i>Start for Free
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn lp-btn-ghost">
                <i class="fas fa-sign-in-alt me-2"></i>Sign In
            </a>
        </div>
    </div>
</section>
