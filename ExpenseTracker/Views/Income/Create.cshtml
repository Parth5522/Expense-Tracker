@model ExpenseTracker.Models.Income
@{
    ViewData["Title"] = "Add Income";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold"><i class="fas fa-plus-circle me-2 text-success"></i>Add Income</h1>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
    <div class="card" style="max-width:600px">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Monthly Salary" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Amount" class="form-label fw-semibold"></label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Source" class="form-label fw-semibold"></label>
                    <select asp-for="Source" asp-items="Html.GetEnumSelectList<ExpenseTracker.Models.IncomeSource>()" class="form-select"></select>
                    <span asp-validation-for="Source" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Date" class="form-label fw-semibold"></label>
                    <input asp-for="Date" class="form-control" type="date" />
                    <span asp-validation-for="Date" class="text-danger small"></span>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Currency" class="form-label fw-semibold"></label>
                        <select asp-for="Currency" class="form-select">
                            @if (ViewBag.Currencies != null)
                            {
                                foreach (var c in (List<ExpenseTracker.Models.Currency>)ViewBag.Currencies)
                                {
                                    <option value="@c.Code">@c.Code - @c.Name</option>
                                }
                            }
                            else
                            {
                                <option value="USD">USD - US Dollar</option>
                                <option value="EUR">EUR - Euro</option>
                                <option value="GBP">GBP - British Pound</option>
                                <option value="INR">INR - Indian Rupee</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ExchangeRate" class="form-label fw-semibold"></label>
                        <input asp-for="ExchangeRate" class="form-control" type="number" step="0.000001" min="0.000001" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
                </div>
                <button type="submit" class="btn btn-success"><i class="fas fa-save me-1"></i>Save Income</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
