@model ExpenseTracker.Models.Income
@{
    ViewData["Title"] = "Delete Income";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold text-danger"><i class="fas fa-trash me-2"></i>Delete Income</h1>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
    <div class="card border-danger" style="max-width:500px">
        <div class="card-body">
            <p class="text-muted">Are you sure you want to delete this income entry?</p>
            <dl class="row">
                <dt class="col-sm-4">Title</dt>
                <dd class="col-sm-8">@Model.Title</dd>
                <dt class="col-sm-4">Amount</dt>
                <dd class="col-sm-8 text-success fw-bold">@Model.Currency @Model.Amount.ToString("N2")</dd>
                <dt class="col-sm-4">Date</dt>
                <dd class="col-sm-8">@Model.Date.ToString("MMM dd, yyyy")</dd>
            </dl>
            <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Yes, Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
