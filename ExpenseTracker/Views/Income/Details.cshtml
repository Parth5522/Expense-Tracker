@model ExpenseTracker.Models.Income
@{
    ViewData["Title"] = "Income Details";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold"><i class="fas fa-info-circle me-2 text-info"></i>Income Details</h1>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
    <div class="card" style="max-width:500px">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Title</dt>
                <dd class="col-sm-8">@Model.Title</dd>
                <dt class="col-sm-4">Amount</dt>
                <dd class="col-sm-8 fw-bold text-success">@Model.Currency @Model.Amount.ToString("N2")</dd>
                <dt class="col-sm-4">Source</dt>
                <dd class="col-sm-8"><span class="badge bg-success">@Model.Source</span></dd>
                <dt class="col-sm-4">Date</dt>
                <dd class="col-sm-8">@Model.Date.ToString("MMMM dd, yyyy")</dd>
                <dt class="col-sm-4">Description</dt>
                <dd class="col-sm-8">@(Model.Description ?? "-")</dd>
                <dt class="col-sm-4">Created</dt>
                <dd class="col-sm-8">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>
            </dl>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2"><i class="fas fa-edit me-1"></i>Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>
</div>
