@model IEnumerable<ExpenseTracker.Models.Income>
@{
    ViewData["Title"] = "Income";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold"><i class="fas fa-hand-holding-usd me-2 text-success"></i>Income</h1>
        <div>
            <a asp-action="Export" class="btn btn-outline-success me-2"><i class="fas fa-download me-1"></i>Export CSV</a>
            <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus me-1"></i>Add Income</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Title</th>
                                <th>Source</th>
                                <th class="text-end">Amount</th>
                                <th>Currency</th>
                                <th>Description</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Date.ToString("MMM dd, yyyy")</td>
                                    <td><strong>@item.Title</strong></td>
                                    <td><span class="badge bg-success">@item.Source</span></td>
                                    <td class="text-end fw-bold text-success">@item.Amount.ToString("N2")</td>
                                    <td>@item.Currency</td>
                                    <td><small class="text-muted">@item.Description</small></td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit"><i class="fas fa-edit"></i></a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Delete this income entry?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">No income entries yet</h5>
                    <a asp-action="Create" class="btn btn-success mt-2"><i class="fas fa-plus me-1"></i>Add First Income</a>
                </div>
            }
        </div>
    </div>
</div>
