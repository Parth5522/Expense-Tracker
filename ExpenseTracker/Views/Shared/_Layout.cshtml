@inject Microsoft.AspNetCore.Identity.SignInManager<ExpenseTracker.Models.ApplicationUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expense Tracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ExpenseTracker.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- ===== Top Navbar ===== -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container-fluid">
            @if (SignInManager.IsSignedIn(User))
            {
                <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle sidebar">
                    <i class="fas fa-bars"></i>
                </button>
            }
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-wallet me-2"></i>Expense Tracker
            </a>

            @if (!SignInManager.IsSignedIn(User))
            {
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPublic" aria-controls="navbarPublic" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarPublic">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item ms-1">
                            <a class="nav-link btn-nav-pill" asp-controller="Account" asp-action="Register">
                                <i class="fas fa-user-plus me-1"></i>Register
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                var displayName = User.FindFirst("DisplayName")?.Value
                    ?? User.Identity?.Name
                    ?? "Account";
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link btn-nav-pill d-none d-md-flex align-items-center" asp-area="" asp-controller="Expenses" asp-action="Create">
                            <i class="fas fa-plus me-1"></i>Add Expense
                        </a>
                    </li>
                    <li class="nav-item dropdown ms-2">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user-circle me-1"></i>
                            <span class="d-none d-sm-inline">@displayName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li class="px-3 py-2 small text-muted">
                                <i class="fas fa-user me-1"></i>@displayName
                            </li>
                            <li><hr class="dropdown-divider my-1" /></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="fas fa-id-card me-2"></i>Profile
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fas fa-sign-out-alt me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            }
        </div>
    </nav>

    <!-- ===== Page Wrapper ===== -->
    <div class="page-wrapper">
        @if (SignInManager.IsSignedIn(User))
        {
            <!-- Sidebar overlay (mobile) -->
            <div class="sidebar-overlay" id="sidebarOverlay"></div>

            <!-- ===== Sidebar ===== -->
            <aside class="sidebar" id="sidebar">
                <p class="sidebar-section-title">Main</p>
                <ul class="sidebar-nav">
                    <li>
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-chart-line"></i><span>Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav-link" asp-area="" asp-controller="Expenses" asp-action="Index">
                            <i class="fas fa-receipt"></i><span>Expenses</span>
                        </a>
                    </li>
                    <li>
                        <a class="nav-link" asp-area="" asp-controller="Expenses" asp-action="Create">
                            <i class="fas fa-plus-circle"></i><span>Add Expense</span>
                        </a>
                    </li>
                </ul>

                @if (User.IsInRole("Admin"))
                {
                    <p class="sidebar-section-title">Finance</p>
                    <ul class="sidebar-nav">
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Income" asp-action="Index">
                                <i class="fas fa-dollar-sign"></i><span>Income</span>
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Budgets" asp-action="Index">
                                <i class="fas fa-piggy-bank"></i><span>Budgets</span>
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Goals" asp-action="Index">
                                <i class="fas fa-bullseye"></i><span>Goals</span>
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Recurring" asp-action="Index">
                                <i class="fas fa-sync-alt"></i><span>Recurring</span>
                            </a>
                        </li>
                    </ul>

                    <p class="sidebar-section-title">Insights</p>
                    <ul class="sidebar-nav">
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Reports" asp-action="Index">
                                <i class="fas fa-chart-bar"></i><span>Reports</span>
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Tags" asp-action="Index">
                                <i class="fas fa-tags"></i><span>Tags</span>
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Notifications" asp-action="Index">
                                <i class="fas fa-bell"></i><span>Notifications</span>
                            </a>
                        </li>
                    </ul>

                    <p class="sidebar-section-title">System</p>
                    <ul class="sidebar-nav">
                        <li>
                            <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-shield-alt"></i><span>Admin</span>
                            </a>
                        </li>
                    </ul>
                }

                <div class="sidebar-footer">
                    <a class="nav-link" asp-controller="Account" asp-action="Profile" style="display:flex;align-items:center;gap:.75rem;color:#475569;">
                        <i class="fas fa-user-circle" style="color:#94a3b8;width:20px;text-align:center;font-size:1.1rem;"></i>
                        <span style="font-size:.875rem;font-weight:500;">Profile</span>
                    </a>
                </div>
            </aside>
        }

        <!-- ===== Main Content ===== -->
        <div class="main-content">
            @{
                var successMsg = TempData["SuccessMessage"] ?? TempData["Success"];
                var errorMsg = TempData["ErrorMessage"] ?? TempData["Error"];
            }
            @if (successMsg != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@successMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (errorMsg != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@errorMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- ===== Footer ===== -->
    <footer class="footer">
        <i class="fas fa-wallet me-1" style="color:#c7d2fe;"></i>
        &copy; 2026 Expense Tracker &mdash; Track Your Spending Wisely
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
