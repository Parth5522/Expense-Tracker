@model IEnumerable<ExpenseTracker.Models.Tag>
@{
    ViewData["Title"] = "Tags";
}

<div class="fade-in">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-tags"></i>Tags</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Tag
        </a>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-tags me-2 text-primary"></i>All Tags
                <span class="badge bg-primary ms-1">@Model.Count()</span>
            </span>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Color</th>
                                <th>Name</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tag in Model)
                            {
                                <tr>
                                    <td>
                                        <span style="display:inline-block;width:24px;height:24px;border-radius:4px;background-color:@tag.Color;"></span>
                                    </td>
                                    <td><strong>@tag.Name</strong></td>
                                    <td class="td-actions text-end">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@tag.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@tag.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-tags"></i>
                    <h3>No Tags Yet</h3>
                    <p>Create tags to categorize your expenses and income</p>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Create First Tag
                    </a>
                </div>
            }
        </div>
    </div>
</div>
